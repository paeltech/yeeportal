# App URL (used in document download email links)
PUBLIC_APP_URL=http://localhost:5173

# Demo auth bypass when Supabase is not configured (development only)
DEV_BYPASS_AUTH=true

# Supabase — required for production
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Client-side Supabase (Vite exposes VITE_ prefixed vars)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Email delivery via Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=YEE Portal <documents@yee.or.tz>
