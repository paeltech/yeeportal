# Supabase — required for production
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-jwt-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt-key

# Vite client (browser) — must match Supabase URL/anon key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-jwt-key

# Lovable / Next-style names (also supported)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# App URL (document download email links)
PUBLIC_APP_URL=http://localhost:5173

# Set false when Supabase is configured
DEV_BYPASS_AUTH=false

# Email delivery via Resend (optional)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=YEE Portal <documents@yee.or.tz>

# Run `python3 scripts/sync-env.py` after `supabase link` to populate keys from CLI
